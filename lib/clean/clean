#!/usr/bin/env bash

# --------------------------------------------------------------------------------------------------
# Clean management commands
# --------------------------------------------------------------------------------------------------
source "${SCRIPT_DIR}/lib/clean/xfce"

# Usage for the clean command and its sub commands
# --------------------------------------------------------------------------------------------------
clean::usage()
{
    cat <<USAGE
Usage:
  clean [COMMAND] [ARGS...] [OPTIONS]

Options:
  -h, --help        Print out usage

Commands:
  all [--keep N]    Clean nix store and generations, and orphaned boot kernels
  boot              Remove orphaned /boot/kernels files whose store paths no longer exist
  dec               Clean decrypted files from git and disk
  pkg               Clean the given package out of the nix store
  store             Clean the nix store
  vm                Clean the current vm (qcow2, result and store)
  xfce              Clean various xfce components
USAGE

    log::ln "\nExamples:"
    log::subln "Clean nix store only: ${green}./${SCRIPT} clean store${none}"
    log::subln "Clean nix store and generations: ${green}./${SCRIPT} clean all${none}"
    log::subln "Clean nix store package: ${green}./${SCRIPT} clean pkg /nix/store/1234${none}"
    log::subln "Clean decrypted files from git and disk: ${green}./${SCRIPT} clean dec${none}"
    echo
    exit
}


# Parse the clean commands and execute
# --------------------------------------------------------------------------------------------------
clean::run()
{
    utils::help "$@" "clean::usage"

    # Parse the clean commnand
    local command=$1; shift
    case "$command" in
        all) clean::all "$@" ;;
        boot) clean::boot ;;
        dec) clean::dec "$@" ;;
        pkg) clean::pkg "$@" ;;
        store) clean::store ;;
        vm) clean::vm ;;
        xfce) clean::xfce::run "$@" ;;
        *) log::error "Invalid clean command: ${cyan}${command}${none}"; clean::usage ;;
    esac
}

# Clean the decrypted files from git and disk
# --------------------------------------------------------------------------------------------------
clean::dec()
{
  flake::restore
}

# Clean the given package from the nix store
# --------------------------------------------------------------------------------------------------
clean::pkg()
{
    nix-store --delete "$@"
}

# Clean nix store and generations, then clean orphaned boot kernel files
# - --keep N  Keep the N most recent system generations (default: delete all old)
# --------------------------------------------------------------------------------------------------
clean::all()
{
    local keep=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --keep) keep="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    if [[ $keep -gt 0 ]]; then
        log::ls "Deleting system generations, keeping last ${cyan}${keep}${none}"
        $SUDO nix-env --delete-generations "+${keep}" --profile /nix/var/nix/profiles/system
        nix-store --gc
    else
        log::ls "Deleting all old system generations"
        nix-collect-garbage -d
    fi

    clean::boot
}

# Remove orphaned files in /boot/kernels whose nix store paths no longer exist
# --------------------------------------------------------------------------------------------------
clean::boot()
{
    log::header1 "Clean orphaned /boot/kernels files"
    local found=0
    for f in /boot/kernels/*; do
        [[ -e "$f" ]] || continue
        local hash
        hash=$(basename "$f" | cut -d- -f1)
        if ! ls /nix/store/${hash}-* &>/dev/null 2>&1; then
            log::ls "Removing orphaned: ${cyan}${f}${none}"
            $SUDO rm "$f"
            ((found++)) || true
        fi
    done
    [[ $found -eq 0 ]] && log::ls "No orphaned boot kernel files found"
}

# Clean up nix store
# --------------------------------------------------------------------------------------------------
clean::store()
{
    nix-store --gc
}

# Clean up the vm
# --------------------------------------------------------------------------------------------------
clean::vm()
{
    # Delete the VM image
    local image="nixos.qcow2"
    if [ -f $image ]; then
        log::ln "Removing VM qcow2 image ${cyan}${image}${none}"
        rm $image
    fi

    # Read the result link for the VM configuration
    if [ -e result ]; then
        local store_path=$(readlink result)

        # Remove the store item
        log::ln "Removing store artifact ${cyan}${store_path}${none}"
        rm result
        nix-store --delete $store_path
    fi
}
