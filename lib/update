#!/usr/bin/env bash

# Update the system
# 
# ## Features
#
# --------------------------------------------------------------------------------------------------

# Usage for the update command and its sub commands
# --------------------------------------------------------------------------------------------------
update::usage()
{
    cat <<USAGE
Usage:
  update [COMMAND] [ARGS...] [OPTIONS]

Options:
  -h, --help        Print out usage
  --boot            Stage config for next boot instead of switching immediately
  --impure          Pass impure into the system update
  --reset-xfce      Remove existing xfce configuration during system update

Commands:
  flake [MACHINE]   Update the given machine's flake.lock or root base.lock if not given
  system [MACHINE]  Update system with given machine's configuration or hostname's if not given
USAGE

    log::ln "\nExamples:"
    log::subln "Update flake: ${green}./${SCRIPT} update flake${none}"
    log::subln "Update system using hostname: ${green}./${SCRIPT} update system${none}"
    log::subln "Update system by name: ${green}./${SCRIPT} update system macbook${none}"
    log::subln "Update the system, resetting xfce: ${green}./${SCRIPT} update system --reset-xfce${none}"
    log::subln "Stage config for next boot: ${green}./${SCRIPT} update system --boot${none}"
    echo
    exit
}

# Parse the update commands and execute
# --------------------------------------------------------------------------------------------------
update::run()
{
    utils::help "$@" "update::usage"

    local command=$1; shift
    case "$command" in
        flake) update::flake "$@" ;;
        profile) update::profile "$@" ;;
        system) update::system "$@" ;;
        *) log::error "Invalid update command: ${cyan}${command}${none}"; update::usage ;;
    esac
}

# Update the flake for the given machine or fallback on the root flake
# - $1 - machine or profile with preceding path prefix 'profiles/' or 'machines/'
# --------------------------------------------------------------------------------------------------
update::flake()
{
    core::preamble
    log::header1 "Update flake"

    MACHINE="$1"
    TARGET="machines/$MACHINE"

    # Switch to target flake
    utils::run pushd "${CONFIG_DIR}"
    if [[ "$MACHINE" != "" ]]; then
        flake::switch $TARGET
        trap flake::restore EXIT
    else
        log::header0 "Switching to base flake"
        $SUDO cp base.nix flake.nix
        $SUDO cp base.lock flake.lock
        $SUDO git add flake.nix flake.lock -f
    fi

    # Update flake
    $SUDO nix flake update

    # Clean up after
    if [[ "$MACHINE" != "" ]]; then
        if [ -e "${CONFIG_DIR}/${TARGET}/flake.nix" ]; then
            $SUDO cp flake.lock "${CONFIG_DIR}/${TARGET}/flake.lock"
        else
            $SUDO cp flake.lock base.lock
        fi
        # cleanup will be done by trap
    else
        cp flake.lock base.lock
        $SUDO git restore --staged flake.nix flake.lock
    fi
    utils::run popd
}

# Update the system with the system configuration changes
# --------------------------------------------------------------------------------------------------
# - $1 - optional hostname to use
update::system()
{
    core::preamble
    log::header1 "Update system version"

    # Set additional flags as specified
    local boot_mode=0
    local reset_xfce=0
    while [ $# -gt 0 ]; do
        local arg=$1; shift
        case "$arg" in
            --boot) boot_mode=1 ;;
            --reset-xfce*) reset_xfce=1 ;;
            *) MACHINE="$arg" ;;
        esac
    done

    # Set the target machine
    if [[ "$MACHINE" == "" ]]; then
        MACHINE=$(hostname)
        log::ls "Using hostname ${cyan}${MACHINE}${none}"
    else
        log::ls "Using given machine name ${cyan}${MACHINE}${none}"
    fi

    TARGET="machines/$MACHINE"
    flake::stage_files "${TARGET}"

    # Cleanup the .config/xfce4 directories to ensure new settings don't conflict
    if [ $reset_xfce -eq 1 ]; then
        _update::removeUserXfceConfigs
        _update::clearXfceFileMarkers
    fi

    # Execute update
    local rebuild_action="switch"
    [ $boot_mode -eq 1 ] && rebuild_action="boot"
    $SUDO nixos-rebuild $rebuild_action $TRACE $IMPURE --flake "${CONFIG_DIR}#target"
    if [ $boot_mode -eq 1 ]; then
        log::info "Configuration staged for next boot. Run 'sudo reboot' to apply."
    fi
}

# Remove user xfce configurations to get a clean point to start from
_update::removeUserXfceConfigs()
{
    local users=$(find /home -mindepth 1 -maxdepth 1)
    users+=('/root')
    for x in ${users[@]}; do
      local target="${x}/.config/xfce4"
      log::ls "Cleaning up: ${cyan}${target}${none}"
      $SUDO rm -rf "$target"
    done
}

# Remove xfce entries from the files tracking logs so the install script treats them as
# never-installed, ensuring they are re-copied even if xfconfd has regenerated them.
_update::clearXfceFileMarkers()
{
    local owned_log="${ROOT_DIR}/nix/files.owned"
    local unowned_log="${ROOT_DIR}/nix/files.unowned"

    for log in "$owned_log" "$unowned_log"; do
        if [[ -f "$log" ]]; then
            log::ls "Clearing xfce markers from ${cyan}${log}${none}"
            local tmp="${log}.tmp"
            $SUDO grep -v '\.config/xfce4' "$log" | $SUDO tee "$tmp" > /dev/null || true
            $SUDO mv "$tmp" "$log"
        fi
    done
}
